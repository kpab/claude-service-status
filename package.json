{
  "name": "claude-service-status",
  "displayName": "Claude Service Status",
  "description": "Unofficial: monitor Claude (Anthropic) service status, outages, and incidents from status.claude.com — right in your VS Code status bar. Not affiliated with Anthropic.",
  "version": "0.1.3",
  "publisher": "kpab",
  "icon": "icon.png",
  "license": "MIT",
  "author": "kpab",
  "keywords": [
    "claude",
    "anthropic",
    "status",
    "service status",
    "statuspage",
    "incident",
    "outage",
    "uptime",
    "downtime",
    "monitor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kpab/claude-service-status.git"
  },
  "bugs": {
    "url": "https://github.com/kpab/claude-service-status/issues"
  },
  "homepage": "https://github.com/kpab/claude-service-status#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeStatus.refresh",
        "title": "Claude Status: Refresh Now"
      },
      {
        "command": "claudeStatus.showDetails",
        "title": "Claude Status: Show Details"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeStatus",
          "title": "Claude Status",
          "icon": "$(cloud)"
        }
      ]
    },
    "views": {
      "claudeStatus": [
        {
          "id": "claudeStatus.statusView",
          "name": "Status",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Claude Status",
      "properties": {
        "claudeStatus.statusPageUrl": {
          "type": "string",
          "default": "https://status.claude.com",
          "description": "Base URL of the Atlassian Statuspage to monitor."
        },
        "claudeStatus.refreshInterval": {
          "type": "number",
          "default": 60,
          "minimum": 15,
          "description": "Polling interval in seconds (minimum 15 to respect the Statuspage rate limit)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.4.0"
  }
}
